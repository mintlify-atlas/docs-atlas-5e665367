  "keyFeatures": [
    "Full RDAP protocol support (RFC 7480-7484)",
    "Automatic bootstrap service discovery",
    "Query type auto-detection",
    "Multi-layer RDAP queries (registry + registrar)",
    "Beautiful colored terminal output",
    "Async/await support with Tokio",
    "Disk and memory caching",
    "Configurable bootstrap URLs and TLD overrides",
    "Support for domains, IPs (IPv4/IPv6), CIDR, AS numbers, entities, nameservers"
  ],
  "publicApiSurface": [
    "RdapClient::new() - Create new RDAP client",
    "RdapClient::query() - Execute RDAP query",
    "RdapClient::query_with_referral() - Query with registrar referral support",
    "RdapRequest::new() - Create query request",
    "RdapRequest::detect_type() - Auto-detect query type",
    "RdapRequest::with_server() - Use custom RDAP server",
    "QueryType enum - Domain, Tld, Ip, Autnum, Entity, Nameserver",
    "RdapObject enum - Domain, IpNetwork, Autnum, Entity, Nameserver, Error",
    "Config::load() - Load configuration",
    "RdapDisplay trait - Format output for display"
  ]
}
